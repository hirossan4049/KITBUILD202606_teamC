{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: iOS Simulator (Hot Reload)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "emulatorId": "apple_ios_simulator",
      "env": {
        "DEVELOPER_DIR": "/Applications/Xcode.app/Contents/Developer"
      }
    }
  ]
}
